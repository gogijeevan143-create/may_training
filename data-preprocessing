# --- Part 4: Data Analysis ---

# 1. Create a new column named average_score
df['average_score'] = (df['math_score'] + df['science_score']) / 2

# 2. Find the top 5 students based on average_score
top_5_students = df.nlargest(5, 'average_score')
print("--- Top 5 Students by Average Score ---")
print(top_5_students[['name', 'average_score']], "\n")

# 3. Calculate the correlation between attendance and marks
correlation = df['attendance'].corr(df['average_score'])
print(f"--- Correlation between Attendance and Marks ---")
print(f"Correlation coefficient: {correlation:.4f}\n")

# 4. Group students by gender and calculate average marks
gender_analysis = df.groupby('gender')[['math_score', 'science_score', 'average_score']].mean()
print("--- Average Marks by Gender ---")
print(gender_analysis)
