[Cell 3] Task 3: Data Preprocessing
Code:

Python
# --- Part 3: Data Preprocessing ---

# 1. Convert incorrect data formats (string 'twenty' to int 20)
df['age'] = df['age'].replace('twenty', 20)
df['age'] = pd.to_numeric(df['age'])

# 2. Detect and handle outliers (cap scores at 100, set invalid to NaN)
df.loc[df['math_score'] > 100, 'math_score'] = np.nan
df.loc[df['science_score'] > 100, 'science_score'] = np.nan

# 3. Identify and handle missing values (Impute with Median and Mode)
df['math_score'] = df['math_score'].fillna(df['math_score'].median())
df['science_score'] = df['science_score'].fillna(df['science_score'].median())
df['attendance'] = df['attendance'].fillna(df['attendance'].median())
df['age'] = df['age'].fillna(df['age'].median())
df['gender'] = df['gender'].fillna(df['gender'].mode()[0])

# 4. Convert exam_date into datetime format (handling mixed formats)
df['exam_date'] = pd.to_datetime(df['exam_date'], format='mixed')
df['exam_date'] = df['exam_date'].fillna(df['exam_date'].mode()[0])

# 5. Find and remove duplicate rows
df = df.drop_duplicates()

print("Data cleaning successfully completed.")
print(f"Remaining null values:\n{df.isnull().sum()}")
