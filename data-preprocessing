import pandas as pd
import numpy as np

# Load the dataset
df = pd.read_csv('student_scores.csv')

# --- Part 1: NumPy Operations ---

# Extract math scores, drop NaNs, and convert to NumPy array
math_scores_raw = df['math_score'].dropna().values

# Calculate statistics
mean_score = np.mean(math_scores_raw)
median_score = np.median(math_scores_raw)
max_score = np.max(math_scores_raw)
min_score = np.min(math_scores_raw)

print(f"--- NumPy Statistics ---")
print(f"Mean: {mean_score:.2f}")
print(f"Median: {median_score}")
print(f"Max: {max_score}")
print(f"Min: {min_score}\n")

# Normalize using Min-Max formula
normalized_scores = (math_scores_raw - min_score) / (max_score - min_score)

print(f"--- First 5 Normalized Scores ---")
print(normalized_scores[:5])
